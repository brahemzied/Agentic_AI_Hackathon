# Environment Variables Template for Ubuntu VM Deployment
# Copy this file to .env and update the values

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=dera
PGHOST=localhost
PGPORT=5432
PGDATABASE=dera
PGUSER=postgres
PGPASSWORD=postgres

# =============================================================================
# OpenMetadata Configuration
# =============================================================================
OPENMETADATA_HOST_PORT=http://localhost:8585/api


# Database settings for OpenMetadata
DB_SERVICE_NAME=dera-postgres

# =============================================================================
# n8n Configuration (if using n8n)
# =============================================================================
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme123
N8N_SECURE_COOKIE=false

# =============================================================================
# pgAdmin Configuration (optional)
# =============================================================================
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin123

# =============================================================================
# Application URLs
# =============================================================================
# These will be set automatically by the infrastructure
# OPENMETADATA_URL=http://localhost:8585
# N8N_URL=http://localhost:5678
# GATEWAY_URL=http://your-gateway-ip

# =============================================================================
# Development/Testing
# =============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# JWT Configuration for OpenMetadata
# =============================================================================
# These will be automatically generated during deployment
JWT_PRIVATE_KEY_PATH=/opt/agentic-ai-hackathon/conf/private_key.der
JWT_PUBLIC_KEY_PATH=/opt/agentic-ai-hackathon/conf/public_key.der
JWT_KEY_ID=auto-generated-uuid
JWT_ISSUER=your-domain.com
JWT_TOKEN=your-jwt-token-here

# =============================================================================
# OpenMetadata Server Configuration
# =============================================================================
OPENMETADATA_CONFIG_PATH=/opt/agentic-ai-hackathon/conf/openmetadata.yaml

# =============================================================================
# OpenMetadata Server Configuration (Container)
# =============================================================================
# Configuration file path inside container
OPENMETADATA_CONFIG_PATH=/opt/conf/openmetadata.yaml

# Server binding configuration
OPENMETADATA_SERVER_LISTEN=0.0.0.0
OPENMETADATA_SERVER_PORT=8585
SERVER_HOST_IP=0.0.0.0

# Database connection (container names)
OPENMETADATA_DATABASE_HOST=mysql
OPENMETADATA_DATABASE_PORT=3306
OPENMETADATA_ELASTICSEARCH_HOST=elasticsearch
OPENMETADATA_ELASTICSEARCH_PORT=9200
